#include <stdio.h>
/*
ao executar o programa via cmd
tudo digitado apos o nome do programa
é contabilizado como argumento
o argc quarda a quantidade de argumentos 
e o argv os argumentos
*/
int main(int argc, char *argv[]){
	int i;
	
	if(argc > 1){
		printf("Foram inseridos %d argumentos:\n\n", argc);
		for(i = 0; i < argc; i++){
			printf("%s\n", argv[i]);
		}
	}else{
		printf("Não forma inseridos argumentos no programa.\n");
	}
}